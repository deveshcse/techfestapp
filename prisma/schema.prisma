generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  user
  organizer
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          UserRole  @default(user)
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  createdTechFests TechFest[] @relation("TechFestCreatedBy")
  updatedTechFests TechFest[] @relation("TechFestUpdatedBy")

  createdActivities Activity[] @relation("ActivityCreatedBy")
  updatedActivities Activity[] @relation("ActivityUpdatedBy")

  organizedActivities Activity[] @relation("ActivityOrganizers")

  // registrations done by this user
  registrations Registration[] @relation("UserRegistrations")

  // registrations this user checked-in (organizer/volunteer role)
  markedAttendances Registration[] @relation("AttendanceMarkedBy")


  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model TechFest {
  id Int @id @default(autoincrement())

  title       String
  description String
  start_date  DateTime
  end_date    DateTime
  venue       String
  published   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  updatedById String?

  createdBy User  @relation("TechFestCreatedBy", fields: [createdById], references: [id])
  updatedBy User? @relation("TechFestUpdatedBy", fields: [updatedById], references: [id])

  activities Activity[]

  @@map("tech_fest")
}

enum ActivityStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

enum ActivityType {
  WORKSHOP
  CODING
  ROBOTICS
  TALK
  CULTURAL
  OTHER
}

model Activity {
  id Int @id @default(autoincrement())

  // relation
  techfestId Int
  techfest   TechFest @relation(fields: [techfestId], references: [id], onDelete: Cascade)

  // basic info
  title       String
  description String?
  venue    String?
  type        ActivityType @default(OTHER)
  rules       String[] @default([])

  // scheduling
  startDateTime DateTime
  endDateTime   DateTime

  // limits
  capacity Int? @default(100)

  // status
  status ActivityStatus @default(DRAFT)

  // audit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById   String
  updatedById   String?
  organizedById String?

  createdBy   User? @relation("ActivityCreatedBy", fields: [createdById], references: [id])
  updatedBy   User? @relation("ActivityUpdatedBy", fields: [updatedById], references: [id])
  organizers User[] @relation("ActivityOrganizers")

  registrations Registration[] @relation("ActivityRegistrations")

  @@index([techfestId])
  @@map("activities")
}


enum RegistrationStatus {
  PENDING    // For events requiring manual approval
  CONFIRMED  // Standard active registration
  CANCELLED  // User withdrew
  WAITLISTED // Activity was full
  ATTENDED   // User actually showed up
}


model Registration {
  id         Int                @id @default(autoincrement())
  userId     String
  activityId Int
  status     RegistrationStatus @default(CONFIRMED)
  
  // --- Attendance Tracking ---
  attended           Boolean   @default(false)
  attendedAt         DateTime?
  attendanceMarkedBy String?   // Record WHICH organizer/volunteer checked them in

  // --- Feedback/Audit ---
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  feedback   String?   @db.Text   // Post-event feedback from the user
  rating     Int?                 // 1-5 star rating
  
  // --- Future Proofing ---
  metadata   Json?     @default("{}") // Store arbitrary data (e.g., custom form responses)
  notes      String?   @db.Text       // Internal notes for organizers

  // --- Relations ---
  user       User     @relation("UserRegistrations", fields: [userId], references: [id], onDelete: Cascade)
  activity   Activity @relation("ActivityRegistrations", fields: [activityId], references: [id], onDelete: Cascade)
  checkInBy  User?    @relation("AttendanceMarkedBy", fields: [attendanceMarkedBy], references: [id])

  @@unique([userId, activityId])
  @@index([userId])
  @@index([activityId])
  @@map("registrations")
}